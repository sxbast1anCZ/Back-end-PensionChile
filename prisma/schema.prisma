// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS - Estados y tipos
// =====================================================

// Estados del pago
enum EstadoPago {
  PENDIENTE
  PAGADO
  FALLIDO
  CANCELADO
  EXPIRADO
  REEMBOLSADO

  @@map("estado_pago")
}

// Métodos de pago
enum MetodoPago {
  TARJETA_CREDITO
  TARJETA_DEBITO
  TRANSFERENCIA
  WEBPAY
  TRANSBANK

  @@map("metodo_pago")
}

// Estados del reporte
enum EstadoReporte {
  PENDIENTE
  EN_REVISION
  RESUELTO
  RECHAZADO

  @@map("estado_reporte")
}

// =====================================================
// MÓDULO DE USUARIOS - Gestión de cuentas
// =====================================================

// Tabla principal de usuarios
model Usuario {
  id                Int      @id @default(autoincrement()) @map("id_usuario")
  rut               String   @unique @db.VarChar(12) @map("rut") // RUT chileno XX.XXX.XXX-X
  nombreUsuario     String   @db.VarChar(100) @map("nombre_usuario")
  primerApellido    String   @db.VarChar(100) @map("primer_apellido")
  segundoApellido   String?  @db.VarChar(100) @map("segundo_apellido")
  telefono          String   @db.VarChar(15) @map("telefono") // Aumentado para +56 9 XXXX XXXX
  correoElectronico String   @unique @db.VarChar(320) @map("correo_electronico") // RFC 5321 estándar
  contrasena        String   @db.VarChar(255) @map("contrasena") // Para hash bcrypt
  tipoUsuarioId     Int      @map("tipo_usuario_id")
  estadoUsuarioId   Int      @map("estado_usuario_id")
  fechaCreacion     DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")
  
  // Relaciones principales
  tipoUsuario       TipoUsuario   @relation(fields: [tipoUsuarioId], references: [id], onDelete: Restrict)
  estadoUsuario     EstadoUsuario @relation(fields: [estadoUsuarioId], references: [id], onDelete: Restrict)
  universitario     Universitario?
  propietario       Propietario?
  
  // Relaciones con funcionalidades
  publicaciones     Publicacion[]
  resenas           Resena[]
  ordenesPago       OrdenPago[]
  favoritos         Favorito[]
  reportes          Reporte[]
  contactosEnviados Contacto[]    @relation("ContactoUniversitario")
  contactosRecibidos Contacto[]   @relation("ContactoPropietario")
  
  // Índices para optimización
  @@index([correoElectronico], name: "idx_usuario_email")
  @@index([rut], name: "idx_usuario_rut")
  @@index([tipoUsuarioId], name: "idx_usuario_tipo")
  @@index([estadoUsuarioId], name: "idx_usuario_estado")
  @@index([fechaCreacion], name: "idx_usuario_fecha_creacion")
  
  @@map("usuarios")
}

// Catálogo de tipos de usuario
model TipoUsuario {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  activo      Boolean   @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")
  
  usuarios    Usuario[]
  
  @@map("tipos_usuario")
}

// Catálogo de estados de usuario
model EstadoUsuario {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  activo      Boolean   @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")
  
  usuarios    Usuario[]
  
  @@map("estados_usuario")
}

// Perfil específico de universitarios
model Universitario {
  id                 Int      @id @default(autoincrement())
  usuarioId          Int      @unique @map("usuario_id")
  ciudad             String   @db.VarChar(100)
  region             String   @db.VarChar(100)
  universidadEstudio String   @db.VarChar(255) @map("universidad_estudio") // Para compatibilidad
  universidadId      Int?     @map("universidad_id") // FK opcional
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  
  usuario            Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  universidad        ListadoUniversidad?   @relation(fields: [universidadId], references: [id], onDelete: SetNull)
  
  @@index([universidadId], name: "idx_universitario_universidad")
  @@index([ciudad], name: "idx_universitario_ciudad")
  
  @@map("universitarios")
}

// Perfil específico de propietarios
model Propietario {
  id                    Int      @id @default(autoincrement())
  usuarioId             Int      @unique @map("usuario_id")
  biografia             String?  @db.Text
  cantidadPublicaciones Int      @default(0) @map("cantidad_publicaciones")
  fechaCreacion         DateTime @default(now()) @map("fecha_creacion")
  
  usuario               Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@map("propietarios")
}

// =====================================================
// MÓDULO DE UBICACIONES - Sistema geográfico de Chile
// =====================================================

// Regiones de Chile (15 regiones)
model Region {
  id            Int         @id @default(autoincrement())
  codigo        String      @unique @db.VarChar(5) // "01", "02", "RM", etc.
  nombre        String      @unique @db.VarChar(100)
  activo        Boolean     @default(true)
  fechaCreacion DateTime    @default(now()) @map("fecha_creacion")
  
  provincias    Provincia[]
  comunas       Comuna[]
  ubicaciones   Ubicacion[]
  
  @@index([activo], name: "idx_region_activo")
  
  @@map("regiones")
}

// Provincias de Chile (56 provincias)
model Provincia {
  id            Int         @id @default(autoincrement())
  regionId      Int         @map("region_id")
  codigo        String      @unique @db.VarChar(10)
  nombre        String      @db.VarChar(100)
  activo        Boolean     @default(true)
  fechaCreacion DateTime    @default(now()) @map("fecha_creacion")
  
  region        Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)
  comunas       Comuna[]
  ubicaciones   Ubicacion[]
  
  @@unique([regionId, nombre], name: "unique_provincia_region")
  @@index([regionId], name: "idx_provincia_region")
  @@index([activo], name: "idx_provincia_activo")
  
  @@map("provincias")
}

// Comunas de Chile (346 comunas)
model Comuna {
  id            Int         @id @default(autoincrement())
  provinciaId   Int         @map("provincia_id")
  regionId      Int         @map("region_id") // Para consultas directas
  codigo        String      @unique @db.VarChar(10)
  nombre        String      @db.VarChar(100)
  activo        Boolean     @default(true)
  fechaCreacion DateTime    @default(now()) @map("fecha_creacion")
  
  provincia     Provincia   @relation(fields: [provinciaId], references: [id], onDelete: Cascade)
  region        Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)
  ubicaciones   Ubicacion[]
  
  @@unique([provinciaId, nombre], name: "unique_comuna_provincia")
  @@index([provinciaId], name: "idx_comuna_provincia")
  @@index([regionId], name: "idx_comuna_region")
  @@index([activo], name: "idx_comuna_activo")
  
  @@map("comunas")
}

// Ubicaciones específicas con coordenadas
model Ubicacion {
  id              Int                  @id @default(autoincrement())
  regionId        Int                  @map("region_id")
  provinciaId     Int                  @map("provincia_id")
  comunaId        Int                  @map("comuna_id")
  calle           String               @db.VarChar(255)
  numero          String?              @db.VarChar(20)
  referencias     String?              @db.Text
  latitud         Decimal?             @db.Decimal(10, 8)
  longitud        Decimal?             @db.Decimal(11, 8)
  fechaCreacion   DateTime             @default(now()) @map("fecha_creacion")
  
  region          Region               @relation(fields: [regionId], references: [id], onDelete: Restrict)
  provincia       Provincia            @relation(fields: [provinciaId], references: [id], onDelete: Restrict)
  comuna          Comuna               @relation(fields: [comunaId], references: [id], onDelete: Restrict)
  publicaciones   Publicacion[]
  universidades   ListadoUniversidad[]
  
  @@index([regionId], name: "idx_ubicacion_region")
  @@index([provinciaId], name: "idx_ubicacion_provincia")
  @@index([comunaId], name: "idx_ubicacion_comuna")
  @@index([latitud, longitud], name: "idx_ubicacion_coordenadas")
  
  @@map("ubicaciones")
}

// Catálogo de universidades chilenas
model ListadoUniversidad {
  id               Int            @id @default(autoincrement())
  nombreUniversidad String        @db.VarChar(255) @map("nombre_universidad")
  ubicacionId      Int            @map("ubicacion_id")
  activo           Boolean        @default(true)
  fechaCreacion    DateTime       @default(now()) @map("fecha_creacion")
  
  ubicacion        Ubicacion      @relation(fields: [ubicacionId], references: [id], onDelete: Restrict)
  universitarios   Universitario[]
  
  @@unique([nombreUniversidad, ubicacionId], name: "unique_universidad_ubicacion")
  @@index([activo], name: "idx_universidad_activo")
  @@index([nombreUniversidad], name: "idx_universidad_nombre")
  
  @@map("listado_universidades")
}

// =====================================================
// MÓDULO DE PUBLICACIONES - Gestión de pensiones
// =====================================================

// Publicaciones de alojamiento
model Publicacion {
  id                   Int                 @id @default(autoincrement())
  propietarioId        Int                 @map("propietario_id")
  titulo               String              @db.VarChar(255)
  descripcion          String?             @db.Text
  precioMensual        Decimal             @db.Decimal(10, 2) @map("precio_mensual")
  
  // Servicios incluidos (RF-003, RF-005)
  tieneBanoPropio      Boolean?            @map("tiene_bano_propio")
  tieneCocinaPropia    Boolean?            @map("tiene_cocina_propia")
  tieneLavanderia      Boolean?            @map("tiene_lavanderia")
  tieneAccesibilidad   Boolean?            @map("tiene_accesibilidad")
  tieneInternet        Boolean?            @map("tiene_internet") // RF-003
  incluyeAlmuerzo      Boolean?            @map("incluye_almuerzo") // RF-005
  
  // Referencias a catálogos
  tipoViviendaId       Int                 @map("tipo_vivienda_id")
  sexoPermitidoId      Int?                @map("sexo_permitido_id") // Nullable
  ubicacionId          Int                 @map("ubicacion_id")
  
  // Premium y estados
  esPremium            Boolean             @default(false) @map("es_premium")
  estadoPublicacion    Int                 @default(1) @map("estado_publicacion") // 1: Activo, 2: Inactivo
  
  // Fechas
  fechaCreacion        DateTime            @default(now()) @map("fecha_creacion")
  fechaActualizacion   DateTime            @updatedAt @map("fecha_actualizacion")
  fechaExpiracion      DateTime?           @map("fecha_expiracion") // Para premium
  
  // Relaciones principales
  propietario          Usuario             @relation(fields: [propietarioId], references: [id], onDelete: Cascade)
  tipoVivienda         TipoVivienda        @relation(fields: [tipoViviendaId], references: [id], onDelete: Restrict)
  sexoPermitido        SexoPermitido?      @relation(fields: [sexoPermitidoId], references: [id], onDelete: SetNull)
  ubicacion            Ubicacion           @relation(fields: [ubicacionId], references: [id], onDelete: Restrict)
  
  // Relaciones con funcionalidades
  fotos                FotoPublicacion[]
  resenas              Resena[]
  ordenesPago          OrdenPago[]
  favoritos            Favorito[]
  reportes             Reporte[]
  contactos            Contacto[]
  
  // Índices para optimización
  @@index([propietarioId], name: "idx_publicacion_propietario")
  @@index([ubicacionId], name: "idx_publicacion_ubicacion")
  @@index([tipoViviendaId], name: "idx_publicacion_tipo_vivienda")
  @@index([esPremium, estadoPublicacion], name: "idx_publicacion_premium_estado")
  @@index([precioMensual], name: "idx_publicacion_precio")
  @@index([fechaCreacion], name: "idx_publicacion_fecha_creacion")
  
  @@map("publicaciones")
}

// Fotos de publicaciones
model FotoPublicacion {
  id            Int         @id @default(autoincrement())
  publicacionId Int         @map("publicacion_id")
  urlSupabase   String      @db.VarChar(500) @map("url_supabase") // URL de Supabase Storage
  nombreArchivo String      @db.VarChar(255) @map("nombre_archivo")
  esPortada     Boolean     @default(false) @map("es_portada")
  orden         Int         @default(0)
  fechaSubida   DateTime    @default(now()) @map("fecha_subida")
  
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  
  @@index([publicacionId, orden], name: "idx_foto_publicacion_orden")
  @@index([esPortada], name: "idx_foto_portada")
  
  @@map("fotos_publicaciones")
}

// Reseñas de publicaciones
model Resena {
  id                 Int         @id @default(autoincrement())
  publicacionId      Int         @map("publicacion_id")
  usuarioId          Int         @map("usuario_id")
  textoResena        String      @db.Text @map("texto_resena")
  calificacion       Int         // 1-10
  fechaCreacion      DateTime    @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime    @updatedAt @map("fecha_actualizacion")
  
  publicacion        Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  usuario            Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@unique([publicacionId, usuarioId], name: "unique_resena_usuario_publicacion")
  @@index([calificacion], name: "idx_resena_calificacion")
  @@index([fechaCreacion], name: "idx_resena_fecha")
  
  @@map("resenas")
}

// =====================================================
// CATÁLOGOS DE PUBLICACIONES
// =====================================================

// Tipos de vivienda
model TipoVivienda {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique @db.VarChar(50)
  descripcion   String?       @db.VarChar(255)
  activo        Boolean       @default(true)
  fechaCreacion DateTime      @default(now()) @map("fecha_creacion")
  
  publicaciones Publicacion[]
  
  @@index([activo], name: "idx_tipo_vivienda_activo")
  
  @@map("tipos_vivienda")
}

// Sexos permitidos en alojamiento
model SexoPermitido {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique @db.VarChar(50) // "Masculino", "Femenino", "Mixto"
  descripcion   String?       @db.VarChar(255)
  activo        Boolean       @default(true)
  fechaCreacion DateTime      @default(now()) @map("fecha_creacion")
  
  publicaciones Publicacion[]
  
  @@index([activo], name: "idx_sexo_permitido_activo")
  
  @@map("sexos_permitidos")
}

// =====================================================
// MÓDULO DE FUNCIONALIDADES
// =====================================================

// RF-005: Sistema de favoritos
model Favorito {
  id            Int         @id @default(autoincrement())
  usuarioId     Int         @map("usuario_id")
  publicacionId Int         @map("publicacion_id")
  fechaCreacion DateTime    @default(now()) @map("fecha_creacion")
  
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  
  @@unique([usuarioId, publicacionId], name: "unique_favorito_usuario_publicacion")
  @@index([usuarioId], name: "idx_favorito_usuario")
  @@index([fechaCreacion], name: "idx_favorito_fecha")
  
  @@map("favoritos")
}

// RF-009: Sistema de reportes
model Reporte {
  id              Int            @id @default(autoincrement())
  publicacionId   Int            @map("publicacion_id")
  usuarioId       Int            @map("usuario_id")
  motivo          String         @db.VarChar(255)
  descripcion     String?        @db.Text
  estado          EstadoReporte  @default(PENDIENTE)
  fechaCreacion   DateTime       @default(now()) @map("fecha_creacion")
  fechaResolucion DateTime?      @map("fecha_resolucion")
  
  publicacion     Publicacion    @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  usuario         Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  
  @@unique([publicacionId, usuarioId], name: "unique_reporte_usuario_publicacion")
  @@index([estado], name: "idx_reporte_estado")
  @@index([fechaCreacion], name: "idx_reporte_fecha")
  
  @@map("reportes")
}

// RF-012: Sistema de contactos con auditoría
model Contacto {
  id              Int       @id @default(autoincrement())
  publicacionId   Int       @map("publicacion_id")
  universitarioId Int       @map("universitario_id")
  propietarioId   Int       @map("propietario_id")
  
  // Datos del contacto
  nombreCompleto  String    @db.VarChar(255) @map("nombre_completo")
  telefono        String    @db.VarChar(20)
  correo          String    @db.VarChar(320)
  mensaje         String    @db.Text
  
  // Estado del contacto
  leido           Boolean   @default(false)
  respondido      Boolean   @default(false)
  fechaEnvio      DateTime  @default(now()) @map("fecha_envio")
  fechaLectura    DateTime? @map("fecha_lectura")
  fechaRespuesta  DateTime? @map("fecha_respuesta")
  
  publicacion     Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  universitario   Usuario     @relation("ContactoUniversitario", fields: [universitarioId], references: [id], onDelete: Cascade)
  propietario     Usuario     @relation("ContactoPropietario", fields: [propietarioId], references: [id], onDelete: Cascade)
  
  // Índices para rendimiento
  @@index([propietarioId, fechaEnvio], name: "idx_contacto_propietario_fecha")
  @@index([universitarioId, fechaEnvio], name: "idx_contacto_universitario_fecha")
  @@index([publicacionId], name: "idx_contacto_publicacion")
  @@index([leido, respondido], name: "idx_contacto_estado")
  
  @@map("contactos")
}

// =====================================================
// MÓDULO DE PAGOS - Sistema Premium con Transbank
// =====================================================

// Catálogo de planes premium
model PlanPremium {
  id                    Int       @id @default(autoincrement())
  nombre                String    @db.VarChar(100)
  descripcion           String?   @db.Text
  precio                Decimal   @db.Decimal(10, 2)
  duracionDias          Int       @map("duracion_dias")
  activo                Boolean   @default(true)
  
  // Beneficios del plan
  destacarPublicacion   Boolean   @default(true) @map("destacar_publicacion")
  aparecerPrimero       Boolean   @default(true) @map("aparecer_primero")
  insigniaEspecial      Boolean   @default(false) @map("insignia_especial")
  multiplicadorVisitas  Int       @default(1) @map("multiplicador_visitas")
  
  fechaCreacion         DateTime  @default(now()) @map("fecha_creacion")
  fechaActualizacion    DateTime  @updatedAt @map("fecha_actualizacion")
  
  ordenes               OrdenPago[]
  
  @@index([activo, precio], name: "idx_plan_activo_precio")
  @@index([duracionDias], name: "idx_plan_duracion")
  
  @@map("planes_premium")
}

// Órdenes de pago con integración Transbank
model OrdenPago {
  id                    Int         @id @default(autoincrement())
  usuarioId             Int         @map("usuario_id")
  publicacionId         Int?        @map("publicacion_id")
  planPremiumId         Int         @map("plan_premium_id")
  
  // Detalles del pago
  monto                 Decimal     @db.Decimal(10, 2)
  moneda                String      @default("CLP") @db.VarChar(3)
  concepto              String      @db.VarChar(500)
  
  // IDs de Transbank (seguros)
  transactionId         String?     @unique @db.VarChar(100) @map("transaction_id")
  buyOrder              String      @unique @db.VarChar(50) @map("buy_order")
  sessionId             String?     @db.VarChar(100) @map("session_id")
  
  // Estados y métodos
  estadoPago            EstadoPago  @default(PENDIENTE) @map("estado_pago")
  metodoPago            MetodoPago? @map("metodo_pago")
  
  // Datos de respuesta Transbank (seguros)
  codigoAutorizacion    String?     @db.VarChar(50) @map("codigo_autorizacion")
  tipoTarjeta           String?     @db.VarChar(20) @map("tipo_tarjeta")
  ultimos4Digitos       String?     @db.VarChar(4) @map("ultimos_4_digitos")
  
  // Auditoría y seguridad
  ipCliente             String?     @db.VarChar(45) @map("ip_cliente")
  userAgent             String?     @db.VarChar(1000) @map("user_agent")
  
  // Fechas de control
  fechaCreacion         DateTime    @default(now()) @map("fecha_creacion")
  fechaPago             DateTime?   @map("fecha_pago")
  fechaExpiracion       DateTime?   @map("fecha_expiracion")
  fechaVencimientoOrden DateTime?   @map("fecha_vencimiento_orden")
  
  // Campos de seguridad
  intentosFallidos      Int         @default(0) @map("intentos_fallidos")
  bloqueado             Boolean     @default(false)
  
  usuario               Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  publicacion           Publicacion? @relation(fields: [publicacionId], references: [id], onDelete: SetNull)
  planPremium           PlanPremium @relation(fields: [planPremiumId], references: [id], onDelete: Restrict)
  
  // Índices para rendimiento y seguridad
  @@index([usuarioId, fechaCreacion], name: "idx_orden_usuario_fecha")
  @@index([estadoPago, fechaCreacion], name: "idx_orden_estado_fecha")
  @@index([buyOrder], name: "idx_orden_buy_order")
  @@index([transactionId], name: "idx_orden_transaction")
  @@index([ipCliente, fechaCreacion], name: "idx_orden_ip_fecha") // Detección de fraude
  @@index([intentosFallidos, bloqueado], name: "idx_orden_seguridad")
  
  @@map("ordenes_pago")
}