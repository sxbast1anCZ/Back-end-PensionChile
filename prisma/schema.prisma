// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma" // Usar ubicación estándar
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabla principal de usuarios
model Usuario {
  idUsuario          Int      @id @default(autoincrement())
  rut                String   @unique @db.VarChar(12) // RUT chileno formato XX.XXX.XXX-X
  nombreUsuario      String   @db.VarChar(100)
  primerApellido     String   @db.VarChar(100)
  segundoApellido    String?  @db.VarChar(100) // Opcional en caso de que no todos tengan segundo apellido
  telefono           String   @db.VarChar(9)   // Exactamente 9 caracteres
  correoElectronico  String   @unique @db.VarChar(255)
  contrasena         String   @db.VarChar(255) // Para hash de contraseña
  tipoUsuario        Int      // Referencia a tabla tipos_usuario
  estadoUsuario      Int      // Referencia a tabla estados_usuario
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  
  // Relaciones
  tipoUsuarioRel     TipoUsuario   @relation(fields: [tipoUsuario], references: [id])
  estadoUsuarioRel   EstadoUsuario @relation(fields: [estadoUsuario], references: [id])
  universitario      Universitario?
  propietario        Propietario?
  publicaciones      Publicacion[] // Nueva relación para publicaciones
  resenas            Resena[]      // Nueva relación para reseñas escritas por el usuario
  
  @@map("usuarios")
}

// Tabla de tipos de usuario (seeder)
model TipoUsuario {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  activo      Boolean   @default(true)
  
  // Relaciones
  usuarios    Usuario[]
  
  @@map("tipos_usuario")
}

// Tabla de estados de usuario (seeder)
model EstadoUsuario {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  activo      Boolean   @default(true)
  
  // Relaciones
  usuarios    Usuario[]
  
  @@map("estados_usuario")
}

// Tabla específica para universitarios
model Universitario {
  id                 Int     @id @default(autoincrement())
  idUsuario          Int     @unique
  ciudad             String  @db.VarChar(100)
  region             String  @db.VarChar(100)
  universidadEstudio String  @db.VarChar(255)
  
  // Relaciones
  usuario            Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  
  @@map("universitarios")
}

// Tabla específica para propietarios
model Propietario {
  id                    Int     @id @default(autoincrement())
  idUsuario             Int     @unique
  biografiaUsuario      String? @db.Text
  cantidadPublicaciones Int     @default(0)
  
  // Relaciones
  usuario               Usuario @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade)
  
  @@map("propietarios")
}

// ===== NUEVAS TABLAS PARA PUBLICACIONES =====

// Tabla principal de publicaciones
model Publicacion {
  id                   Int                    @id @default(autoincrement())
  propietarioId        Int                    // FK al usuario propietario
  titulo               String                 @db.VarChar(255)
  descripcion          String?                @db.Text
  precioMensual        Decimal                @db.Decimal(10,2) // Permite precios hasta 99,999,999.99
  
  // Características booleanas (nullable como solicitaste)
  tieneBañoPropio      Boolean?
  tieneCocinaPropia    Boolean?
  tieneLavanderia      Boolean?
  tieneAccesibilidad   Boolean?
  
  // Referencias a tablas de catálogos
  tipoVivienda         Int                    // FK a tipos_vivienda
  sexosPermitidos      Int?                   // FK a sexos_permitidos (nullable para departamentos)
  
  // Premium y soft delete
  esPremium            Boolean                @default(false)
  estadoPublicacion    Int                    @default(1) // 1: Activo, 2: Eliminado (soft delete)
  
  // Fechas
  fechaCreacion        DateTime               @default(now())
  fechaActualizacion   DateTime               @updatedAt
  fechaExpiracion      DateTime?              // Para publicaciones premium con duración
  
  // Relaciones
  propietario          Usuario                @relation(fields: [propietarioId], references: [idUsuario], onDelete: Cascade)
  tipoViviendaRel      TipoVivienda          @relation(fields: [tipoVivienda], references: [id])
  sexosPermitidosRel   SexosPermitidos?      @relation(fields: [sexosPermitidos], references: [id])
  fotos                FotoPublicacion[]
  resenas              Resena[]               // Nueva relación para reseñas
  
  @@map("publicaciones")
}

// Tabla para almacenar múltiples fotos por publicación
model FotoPublicacion {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  urlSupabase   String      @db.VarChar(500) // URL de Supabase Storage
  nombreArchivo String      @db.VarChar(255)
  esPortada     Boolean     @default(false)  // Una foto principal por publicación
  orden         Int         @default(0)      // Para ordenar las fotos
  fechaSubida   DateTime    @default(now())
  
  // Relaciones
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  
  @@map("fotos_publicaciones")
}

// Tabla de tipos de vivienda (seeder)
model TipoVivienda {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique @db.VarChar(50)
  descripcion   String?       @db.VarChar(255)
  activo        Boolean       @default(true)
  
  // Relaciones
  publicaciones Publicacion[]
  
  @@map("tipos_vivienda")
}

// Tabla de sexos permitidos (seeder)
model SexosPermitidos {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique @db.VarChar(50) // "Masculino", "Femenino", "Mixto", "Sin preferencia"
  descripcion   String?       @db.VarChar(255)
  activo        Boolean       @default(true)
  
  // Relaciones
  publicaciones Publicacion[]
  
  @@map("sexos_permitidos")
}

// Tabla de reseñas para publicaciones
model Resena {
  id            Int         @id @default(autoincrement())
  publicacionId Int         // FK a la publicación reseñada
  usuarioId     Int         // FK al usuario que escribió la reseña
  textoResena   String      @db.Text // Comentario de la reseña
  calificacion  Int         // Calificación del 1 al 10
  fechaCreacion DateTime    @default(now())
  fechaActualizacion DateTime @updatedAt
  
  // Relaciones
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  usuario       Usuario     @relation(fields: [usuarioId], references: [idUsuario], onDelete: Cascade)
  
  // Constraints
  @@unique([publicacionId, usuarioId]) // Un usuario solo puede reseñar una vez por publicación
  @@map("resenas")
}
